{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/icons/(.*)", "dest": "/icons/$1" },
    { "src": "/((?!assets|icons|favicon).*)", "dest": "/index.html" }
  ]
}